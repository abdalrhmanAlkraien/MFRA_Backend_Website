# Database
DB_HOST=localhost
DB_PORT=5460
DB_NAME=mfra
DB_USER=mfra
DB_PASS=mfra

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# JWT
JWT_SECRET=your-256-bit-secret-here-change-in-production
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000

# Email
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@mfra.com
MAIL_FROM_NAME=MFRA Team
ADMIN_EMAIL=admin@mfra.com
MAIL_REPLY_TO=hello@mfra.com

# AWS S3
AWS_S3_BUCKET=mfra-uploads
AWS_ACCESS_KEY=your-access-key
AWS_SECRET_KEY=your-secret-key
AWS_REGION=me-south-1

# CORS
CORS_ORIGINS=http://localhost:5173

# App
APP_PORT=8080

# Default Admin
ADMIN_DEFAULT_EMAIL=admin@mfra.com
ADMIN_DEFAULT_PASSWORD=admin123
ADMIN_DEFAULT_NAME=MFRA Admin
